    {
      "id": "voice",
      "displayName": "Voice / Vocalist",
      "description": "Capture a singer, rapper, choir or distinctive vocal style. Vocals are isolated automatically before training.",
      "icon": "Mic",
      "preprocessing": {
        "enabled": true,
        "model": "vocals_mel_band_roformer.ckpt",
        "keepStems": ["vocals"],
        "extraArgs": {
          "mdxc_segment_size": 256,
          "use_autocast": true
        }
      },
      "autoLabel": {
        "skipMetas": true,
        "transcribeLyrics": true,
        "formatLyrics": false,
        "customTag": "voice clone, ",
        "tagPosition": "prepend"
      },
      "training": {
        "rank": 128,
        "alpha": 256,
        "dropout": 0.05,
        "learningRate": 0.0002,
        "epochs": 3000,
        "batchSize": 1,
        "gradientAccumulation": 2,
        "saveEvery": 500,
        "outputSubdir": "voice"
      },
      "dataset": {
        "minSamples": 8,
        "recommendedSamples": 30,
        "minSampleSeconds": 4,
        "maxSampleSeconds": 30,
        "instructions": "Upload clean vocal recordings — solo singing, rapping, or speech in the target voice. Background music will be removed automatically. 20-40 short clips works best."
      }
    },
